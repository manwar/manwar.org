<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <meta property="og:title"       content="Mohammad Sajid Anwar - Author/Contributor/Editor/Speaker/Founder"/>
    <meta property="og:type"        content="website"/>
    <meta property="og:url"         content="https://manwar.org/"/>
    <meta property="og:image"       content="https://manwar.org/images/manwar.jpg"/>
    <meta property="og:description" content="Mohammad Sajid Anwar - Author/Contributor/Editor/Speaker/Founder"/>
    <meta name="twitter:card"       content="summary" />
    <meta name="twitter:image"      content="https://manwar.org/images/manwar.jpg"/>

    <title>Mohammad Sajid Anwar (MANWAR)</title>
    <meta name="description" content="Mohammad Sajid Anwar - Author/Contributor/Editor/Speaker/Founder"/>

    <link rel="stylesheet" href="<% request.uri_base %>/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="me" href="https://fosstodon.org/@manwar"/>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HWNEE4J2LT"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-HWNEE4J2LT');
    </script>
</head>

<style>
    /* ── Design tokens ──────────────────────────── */
    :root {
        --bg:        #0b0e14;
        --surface:   #131720;
        --surface2:  #1a2030;
        --border:    #252d3e;
        --accent:    #3b82f6;
        --accent2:   #f97316;
        --accent3:   #22d3ee;
        --text:      #e2e8f0;
        --muted:     #64748b;
        --success:   #10b981;
        --warn:      #f59e0b;
        --danger:    #ef4444;
        --font-head: 'Syne', sans-serif;
        --font-mono: 'Space Mono', monospace;
    }

    /* ── Reset / base ───────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; }

    html { scroll-behavior: smooth; }

    body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 14px;
        line-height: 1.7;
        padding-top: 56px;
        overflow-x: hidden;
    }

    a { color: var(--accent); text-decoration: none; }
    a:hover { color: var(--accent3); text-decoration: underline; }

    hr {
        border-color: var(--border);
        margin: 0;
    }

    /* ── Scrollbar ──────────────────────────────── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--accent); }

    /* ── Navbar ─────────────────────────────────── */
    #my-navbar {
        background: rgba(11, 14, 20, 0.95);
        border: none;
        border-bottom: 1px solid var(--border);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow: 0 1px 20px rgba(0,0,0,0.5);
    }

    #my-navbar .navbar-brand {
        font-family: var(--font-head);
        font-weight: 800;
        font-size: 18px;
        color: var(--accent) !important;
        letter-spacing: 0.05em;
    }

    #my-navbar .navbar-nav > li > a,
    #my-navbar .dropdown-menu > li > a {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--muted) !important;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        transition: color 0.2s;
    }

    #my-navbar .navbar-nav > li > a:hover,
    #my-navbar .dropdown-menu > li > a:hover {
        color: var(--text) !important;
        background: transparent !important;
    }

    #my-navbar .dropdown-menu {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 6px 0;
        box-shadow: 0 8px 32px rgba(0,0,0,0.5);
        min-width: 280px;
    }

    #my-navbar .navbar-nav > li.active > a,
    #my-navbar .navbar-nav > li > a:focus {
        background: transparent !important;
        color: var(--accent) !important;
    }

    .navbar-toggle { border-color: var(--border); }
    .navbar-toggle .icon-bar { background-color: var(--muted); }

    /* ── Hero banner ────────────────────────────── */
    .hero-wrap {
        position: relative;
        overflow: hidden;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
    }

    .hero-wrap img.hero-bg {
        width: 100%;
        display: block;
        object-fit: cover;
        max-height: 340px;
        opacity: 0.35;
        filter: saturate(0.6);
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(59,130,246,0.15) 0%, rgba(249,115,22,0.1) 100%);
        pointer-events: none;
    }

    .hero-content {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        display: flex;
        align-items: center;
        padding: 20px 40px;
        gap: 28px;
    }

    .hero-avatar {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        border: 3px solid var(--accent);
        box-shadow: 0 0 24px rgba(59,130,246,0.4);
        flex-shrink: 0;
        object-fit: cover;
    }

    .hero-book {
        width: 90px;
        border-radius: 6px;
        border: 2px solid var(--border);
        box-shadow: 0 4px 16px rgba(0,0,0,0.5);
        flex-shrink: 0;
        transition: transform 0.3s;
    }
    .hero-book:hover { transform: scale(1.05); }

    .hero-text h1 {
        font-family: var(--font-head);
        font-weight: 800;
        font-size: clamp(18px, 3vw, 30px);
        color: var(--text);
        margin: 0 0 4px;
        line-height: 1.15;
    }

    .hero-text .role-badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 4px;
        font-size: 11px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        font-weight: 700;
        margin-right: 6px;
        margin-bottom: 4px;
    }

    .badge-blue  { background: rgba(59,130,246,0.2);  color: var(--accent);  border: 1px solid rgba(59,130,246,0.35); }
    .badge-orange{ background: rgba(249,115,22,0.2);  color: var(--accent2); border: 1px solid rgba(249,115,22,0.35); }
    .badge-cyan  { background: rgba(34,211,238,0.15); color: var(--accent3); border: 1px solid rgba(34,211,238,0.3);  }
    .badge-green { background: rgba(16,185,129,0.15); color: var(--success); border: 1px solid rgba(16,185,129,0.3);  }
    .badge-gold  { background: rgba(245,158,11,0.15); color: var(--warn);    border: 1px solid rgba(245,158,11,0.3);  }

    .dbix-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        background: #080b12;
        border: 1px solid rgba(79,140,255,.35);
        border-radius: 10px;
        font-family: var(--font-mono);
        transition: all .22s ease;
        box-shadow: 0 2px 16px rgba(0,0,0,.4);
        text-decoration: none !important;
        margin-top: 10px;
        display: inline-flex;
    }
    .dbix-badge:hover {
        border-color: rgba(79,140,255,.7);
        box-shadow: 0 4px 24px rgba(79,140,255,.2);
    }

    @media (max-width: 767px) {
        .hero-content { flex-wrap: wrap; padding: 16px 16px; }
        .hero-avatar  { width: 80px; height: 80px; }
        .hero-book    { width: 60px; }
        .hero-text h1 { font-size: 18px; }
    }

    /* ── Section layout ─────────────────────────── */
    .section-wrap {
        padding: 60px 0 40px;
    }

    .section-header {
        font-family: var(--font-head);
        font-weight: 800;
        font-size: clamp(22px, 4vw, 36px);
        color: var(--text);
        position: relative;
        display: inline-block;
        margin-bottom: 36px;
        line-height: 1.1;
    }

    .section-header::after {
        content: '';
        display: block;
        height: 3px;
        width: 48px;
        background: var(--accent);
        margin-top: 8px;
        border-radius: 2px;
    }

    .section-label {
        font-size: 11px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--accent);
        font-weight: 700;
        margin-bottom: 6px;
        display: block;
    }

    /* ── Cards ──────────────────────────────────── */
    .card-dark {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 20px;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .card-dark:hover {
        border-color: var(--accent);
        box-shadow: 0 4px 24px rgba(59,130,246,0.12);
    }

    .card-dark-inner {
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 16px;
    }

    /* ── Who am I ───────────────────────────────── */
    .who-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 20px 16px;
        display: flex;
        align-items: flex-start;
        gap: 14px;
        margin-bottom: 16px;
        transition: border-color 0.2s;
    }
    .who-card:hover { border-color: var(--accent); }
    .who-card img {
        width: 48px; height: 48px;
        border-radius: 50%;
        border: 2px solid var(--border);
        flex-shrink: 0;
        object-fit: cover;
    }
    .who-card p {
        margin: 0;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.6;
    }

    /* ── Patreon grid ───────────────────────────── */
    .patron-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        gap: 8px;
        margin-bottom: 20px;
    }

    .patron-chip {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 10px 12px;
        font-size: 12px;
        color: var(--text);
        text-align: center;
        font-weight: 600;
        transition: all 0.2s;
        line-height: 1.3;
    }
    .patron-chip:hover { border-color: var(--accent); color: var(--accent); }
    .patron-chip a { color: inherit; }
    .patron-chip a:hover { text-decoration: none; }
    .patron-chip.chip-cta {
        border-color: var(--accent2);
        color: var(--accent2);
        cursor: pointer;
    }
    .patron-chip.chip-cta:hover { background: rgba(249,115,22,0.1); }

    /* ── Work history ───────────────────────────── */
    .work-current {
        background: linear-gradient(135deg, rgba(59,130,246,0.1), rgba(16,185,129,0.08));
        border: 1px solid rgba(59,130,246,0.35);
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 28px;
    }

    .work-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 12px;
    }

    .work-item {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 16px;
        transition: border-color 0.2s;
    }
    .work-item:hover { border-color: var(--accent); }
    .work-item .company { font-weight: 700; color: var(--text); font-family: var(--font-head); font-size: 15px; }
    .work-item .role    { color: var(--success); font-size: 12px; margin: 4px 0; }
    .work-item .desc    { color: var(--muted);   font-size: 12px; line-height: 1.5; }

    /* ── Carousel overrides ─────────────────────── */
    .carousel-dark { border-radius: 10px; overflow: hidden; }

    .carousel-dark .item {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        min-height: 160px;
    }

    .carousel-dark .item .card-dark-inner {
        margin: 16px;
    }

    .carousel-dark .item h4 {
        font-family: var(--font-head);
        color: var(--accent);
        font-size: 16px;
        margin: 0 0 6px;
    }

    .carousel-dark .item .subtitle a {
        color: var(--accent3);
        font-weight: 700;
    }

    .carousel-dark .item .body-text { color: var(--muted); font-size: 13px; }

    .carousel-dark .carousel-control {
        background: rgba(59,130,246,0.15) !important;
        width: 40px;
        opacity: 1;
        border-radius: 4px;
    }
    .carousel-dark .carousel-control:hover { background: rgba(59,130,246,0.35) !important; }

    .carousel-dark .carousel-indicators li {
        background-color: var(--border);
        border-color: var(--border);
    }
    .carousel-dark .carousel-indicators li.active {
        background-color: var(--accent);
        border-color: var(--accent);
    }

    /* ── Tabs ───────────────────────────────────── */
    .nav-tabs-dark { border-bottom: 1px solid var(--border); margin-bottom: 20px; flex-wrap: wrap; }

    .nav-tabs-dark > li > a {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--muted);
        background: transparent;
        border: none;
        border-bottom: 2px solid transparent;
        padding: 8px 14px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        border-radius: 0;
        transition: color 0.2s, border-color 0.2s;
    }
    .nav-tabs-dark > li > a:hover {
        color: var(--text);
        background: transparent;
        border-bottom-color: var(--border);
    }
    .nav-tabs-dark > li.active > a,
    .nav-tabs-dark > li.active > a:focus,
    .nav-tabs-dark > li.active > a:hover {
        color: var(--accent);
        background: transparent;
        border: none;
        border-bottom: 2px solid var(--accent);
    }

    /* ── How-to / form controls ─────────────────── */
    .form-control-dark {
        background: var(--surface2);
        border: 1px solid var(--border);
        color: var(--text);
        border-radius: 6px;
        font-family: var(--font-mono);
        font-size: 13px;
    }
    .form-control-dark:focus {
        background: var(--surface2);
        border-color: var(--accent);
        color: var(--text);
        box-shadow: 0 0 0 2px rgba(59,130,246,0.2);
        outline: none;
    }
    .form-control-dark option { background: var(--surface2); }

    label.ctrl-label { color: var(--muted); font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; }

    .btn-primary-dark {
        background: var(--accent);
        border: none;
        color: #fff;
        font-family: var(--font-mono);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 9px 20px;
        border-radius: 6px;
        transition: background 0.2s, transform 0.1s;
    }
    .btn-primary-dark:hover { background: #2563eb; color: #fff; transform: translateY(-1px); }
    .btn-primary-dark:active { transform: translateY(0); }

    /* ── Response panels ────────────────────────── */
    .response-panel {
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 16px;
        margin-top: 12px;
        color: var(--accent3);
        font-size: 13px;
        line-height: 1.7;
        min-height: 40px;
    }
    .response-panel ol, .response-panel ul { padding-left: 20px; color: var(--text); }
    .response-panel li { margin-bottom: 4px; }

    /* ── CPAN recent thumbnails ──────────────────── */
    .cpan-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 8px;
        margin-top: 4px;
    }

    .cpan-item {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 9px 12px;
        font-size: 12px;
        transition: border-color 0.2s;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
    }
    .cpan-item:hover { border-color: var(--accent3); }
    .cpan-item a { color: var(--accent3); display: block; overflow: hidden; text-overflow: ellipsis; }

    /* ── Map::Tube ──────────────────────────────── */
    .map-tube-info {
        background: var(--surface2);
        border-left: 3px solid var(--accent);
        padding: 16px 20px;
        border-radius: 0 8px 8px 0;
        margin-bottom: 20px;
        font-size: 13px;
        color: var(--muted);
    }

    .dist-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
        gap: 6px;
        margin-top: 14px;
    }
    .dist-item {
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: 7px 10px;
        font-size: 11px;
        text-align: center;
        transition: border-color 0.2s;
    }
    .dist-item:hover { border-color: var(--accent); }
    .dist-item a { color: var(--muted); }
    .dist-item a:hover { color: var(--accent); text-decoration: none; }

    /* ── Chart containers ───────────────────────── */
    .chart-wrap {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 20px;
        margin-top: 8px;
        position: relative;
    }

    .chart-wrap canvas {
        max-height: 420px;
    }

    /* ── Spinner ────────────────────────────────── */
    .spinner-wrap {
        display: none;
        text-align: center;
        padding: 40px;
        color: var(--muted);
        font-size: 12px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }
    .spinner-wrap::before {
        content: '';
        display: block;
        width: 28px;
        height: 28px;
        border: 2px solid var(--border);
        border-top-color: var(--accent);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 12px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Footer ─────────────────────────────────── */
    .site-footer {
        background: var(--surface);
        border-top: 1px solid var(--border);
        padding: 32px 0 24px;
        text-align: center;
    }

    .site-footer .social-icons a {
        color: var(--muted);
        font-size: 20px;
        margin: 0 10px;
        transition: color 0.2s, transform 0.2s;
        display: inline-block;
    }
    .site-footer .social-icons a:hover {
        color: var(--accent);
        transform: translateY(-2px);
    }

    .site-footer .footer-links {
        margin-top: 14px;
        font-size: 12px;
    }
    .site-footer .footer-links a {
        color: var(--muted);
        margin: 0 8px;
    }
    .site-footer .footer-links a:hover { color: var(--text); }

    .site-footer small { color: var(--muted); font-size: 11px; }

    /* ── Alert / info banner ────────────────────── */
    .info-banner {
        background: rgba(59,130,246,0.08);
        border: 1px solid rgba(59,130,246,0.25);
        border-radius: 8px;
        padding: 14px 18px;
        font-size: 13px;
        color: var(--text);
        margin-bottom: 24px;
        line-height: 1.6;
    }

    /* ── Embed responsive ────────────────────────── */
    .embed-responsive { border-radius: 8px; overflow: hidden; border: 1px solid var(--border); margin: 16px 0; }

    /* ── Utilities ──────────────────────────────── */
    .text-accent  { color: var(--accent);  }
    .text-accent2 { color: var(--accent2); }
    .text-accent3 { color: var(--accent3); }
    .text-success-dark { color: var(--success); }
    .text-muted-dark   { color: var(--muted);   }

    .no-padding { padding-left: 0; padding-right: 0; }

    /* ── Captcha row ────────────────────────────── */
    #txt_captcha { color: var(--warn); font-weight: 700; font-size: 15px; }
</style>

<body data-spy="scroll" data-target="#my-navbar">

    <!-- ══════════════════════════════════════════
         NAVBAR
    ══════════════════════════════════════════ -->
    <nav class="navbar navbar-inverse navbar-fixed-top" id="my-navbar">
        <div class="container">
            <div class="navbar-header">
                <button type="button" class="navbar-toggle" data-toggle="collapse" data-target="#navbar-collapse">
                    <span class="icon-bar"></span><span class="icon-bar"></span><span class="icon-bar"></span>
                </button>
                <a href="/" class="navbar-brand">MANWAR</a>
            </div>

            <div class="collapse navbar-collapse" id="navbar-collapse">
                <ul class="nav navbar-nav">
                    <li><a href="#who-am-I">Who am I?</a></li>
                    <li class="dropdown">
                        <a href="#" class="dropdown-toggle" data-toggle="dropdown">Latest <b class="caret"></b></a>
                        <ul class="dropdown-menu">
                            <li><a href="#support-patreon">Supporters on Patreon</a></li>
                            <li><a href="#work">Work...</a></li>
                            <li><a href="#what-is-new">What is new?</a></li>
                            <li><a href="#favourite-topics">Favourite Topics</a></li>
                            <li><a href="#how-to">How to...?</a></li>
                        </ul>
                    </li>
                    <li class="dropdown">
                        <a href="#" class="dropdown-toggle" data-toggle="dropdown">Demo <b class="caret"></b></a>
                        <ul class="dropdown-menu">
                            <li><a href="#map-tube">Map::Tube</a></li>
                        </ul>
                    </li>
                    <li class="dropdown">
                        <a href="#" class="dropdown-toggle" data-toggle="dropdown">CPAN <b class="caret"></b></a>
                        <ul class="dropdown-menu">
                            <li><a href="#cpan-recent">Recent Uploads</a></li>
                            <li><a href="#cpan-regulars">Regular Uploads</a></li>
                            <li><a href="#cpan-uploaders">Alltime Uploaders</a></li>
                            <li><a href="#cpan-distributions">Distributions</a></li>
                            <li><a href="#historical-distributions">Historical Distributions</a></li>
                        </ul>
                    </li>
                    <li class="dropdown">
                        <a href="#" class="dropdown-toggle" data-toggle="dropdown">GitHub <b class="caret"></b></a>
                        <ul class="dropdown-menu">
                            <li><a href="#github-pullrequest-tracker">Pull Request Tracker</a></li>
