    <!-- ══════════════════════════════════════════
         WORK
    ══════════════════════════════════════════ -->
    <hr id="work"/>
    <div class="container section-wrap">
        <span class="section-label">Career</span>
        <h2 class="section-header">Work...</h2>

        <% FOREACH current_row IN current %>
        <% FOREACH current_col IN current_row %>
        <div class="work-current">
            <div style="font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--success);margin-bottom:8px;font-weight:700;">▸ Current Position</div>
            <div style="font-family:var(--font-head);font-size:20px;font-weight:800;color:var(--text);margin-bottom:4px;">
                <a href="<% current_col.company_url %>"><% current_col.company_name %></a>
            </div>
            <div style="color:var(--success);font-size:13px;margin-bottom:8px;"><% current_col.job_title %></div>
            <div style="color:var(--muted);font-size:13px;"><% current_col.job_description %></div>
        </div>
        <% END %>
        <% END %>

        <div class="work-grid">
        <% FOREACH work_row IN work %>
        <% FOREACH work_col IN work_row %>
            <div class="work-item">
                <div class="company"><a href="<% work_col.company_url %>"><% work_col.company_name %></a></div>
                <div class="role"><% work_col.job_title %></div>
                <div class="desc"><% work_col.job_description %></div>
            </div>
        <% END %>
        <% END %>
        </div>
    </div>

    <!-- ══════════════════════════════════════════
         WHAT IS NEW
    ══════════════════════════════════════════ -->
    <hr id="what-is-new"/>
    <div class="container section-wrap">
        <span class="section-label">Updates</span>
        <h2 class="section-header">What is new?</h2>

        <div id="what-is-new-slides" class="carousel slide carousel-dark" data-ride="carousel">
            <ol class="carousel-indicators">
                <% FOREACH win_indicator IN win_indicators %>
                <li data-target="#what-is-new-slides" data-slide-to="<% win_indicator.slide_to %>" <% win_indicator.class %>></li>
                <% END %>
            </ol>
            <div class="carousel-inner">
                <% FOREACH win_row IN win %>
                <div class="item<% win_row.active %>">
                    <div class="card-dark-inner" style="margin:16px 50px;">
                        <h4><% win_row.title %></h4>
                        <p class="subtitle"><a href="<% win_row.sub_title_url %>" target="_blank"><% win_row.sub_title_name %></a></p>
                        <p class="body-text"><% win_row.body %></p>
                    </div>
                </div>
                <% END %>
            </div>
            <a class="left carousel-control" href="#what-is-new-slides" data-slide="prev">
                <span class="glyphicon glyphicon-chevron-left"></span>
                <span class="sr-only">Previous</span>
            </a>
            <a class="right carousel-control" href="#what-is-new-slides" data-slide="next">
                <span class="glyphicon glyphicon-chevron-right"></span>
                <span class="sr-only">Next</span>
            </a>
        </div>
    </div>

