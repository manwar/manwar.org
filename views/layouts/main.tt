    <!-- ══════════════════════════════════════════
         HOW TO
    ══════════════════════════════════════════ -->
    <hr id="how-to"/>
    <div class="container section-wrap">
        <span class="section-label">Reference</span>
        <h2 class="section-header">How to...?</h2>

        <ul class="nav nav-tabs nav-tabs-dark" role="tablist">
            <li class="active"><a id="git" href="#git_how_to" role="tab" data-toggle="tab">Git</a></li>
            <li><a id="psql" href="#psql_how_to" role="tab" data-toggle="tab">PostgreSQL</a></li>
        </ul>

        <div id="how-to-spinner" class="spinner-wrap"></div>

        <div class="tab-content">
            <div class="tab-pane active in" id="git_how_to">
                <div class="row">
                    <div class="col-sm-12">
                        <div class="form-group">
                            <label for="git_topic" class="ctrl-label">Select Topic</label>
                            <select id="git_topic" class="form-control form-control-dark">
                                <option value="">-- choose a topic --</option>
                                <% FOREACH git_topic IN git_topics %>
                                <option value="<% git_topic.id %>"><% git_topic.question %></option>
                                <% END %>
                            </select>
                        </div>
                        <div id="git_how_to_response" class="response-panel"></div>
                    </div>
                </div>
            </div>
            <div class="tab-pane" id="psql_how_to">
                <div class="row">
                    <div class="col-sm-12">
                        <div class="form-group">
                            <label for="psql_topic" class="ctrl-label">Select Topic</label>
                            <select id="psql_topic" class="form-control form-control-dark">
                                <option value="">-- choose a topic --</option>
                                <% FOREACH psql_topic IN psql_topics %>
                                <option value="<% psql_topic.id %>"><% psql_topic.question %></option>
                                <% END %>
                            </select>
                        </div>
                        <div id="psql_how_to_response" class="response-panel"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ══════════════════════════════════════════
         MAP::TUBE
    ══════════════════════════════════════════ -->
    <hr id="map-tube"/>
    <div class="container section-wrap">
        <span class="section-label">Demo</span>
        <h2 class="section-header">Map::Tube</h2>

        <ul class="nav nav-tabs nav-tabs-dark" role="tablist">
            <li class="active"><a id="map_tube_summary" href="#map_tube_summary_details" role="tab" data-toggle="tab">Summary</a></li>
            <li><a id="map_tube_demo" href="#map_tube_demo_live" role="tab" data-toggle="tab">Try Me</a></li>
        </ul>

        <div id="map-tube-spinner" class="spinner-wrap"></div>

        <div class="tab-content">
            <div class="tab-pane active in" id="map_tube_summary_details">
                <div class="map-tube-info">
                    <a target="_blank" href="https://metacpan.org/pod/Map::Tube"><strong>Map::Tube</strong></a>
                    is a Lightweight Routing Framework first released on <strong>26th Oct 2010</strong>.
                    As of v3.69, there have been <strong>181</strong> public releases with <strong>41</strong> maps.
                </div>

                <div class="embed-responsive embed-responsive-16by9">
                    <object class="embed-responsive-item" data="https://www.google.com/maps/d/u/0/embed?mid=1VVxj6HvdHDvMPD30lp09kppOZlR6xCY&ehbc=2E312F&noprof=1"></object>
                </div>

                <div class="dist-grid">
                    <% FOREACH dist_row IN dists %>
                    <% FOREACH dist_col IN dist_row %>
                    <div class="dist-item">
                        <a target="_blank" title="<% dist_col.title %>" href="https://metacpan.org/pod/<% dist_col.name %>"><% dist_col.title %></a>
                    </div>
                    <% END %>
                    <% END %>
                </div>
            </div>

            <div class="tab-pane" id="map_tube_demo_live">
                <div class="card-dark" style="max-width:560px;">
                    <div class="form-group">
                        <label for="map_name" class="ctrl-label">Map (City)</label>
                        <select id="map_name" class="form-control form-control-dark">
                            <option value="">-- select map --</option>
                            <% FOREACH map IN maps %>
                            <option value="<% map.name %>"><% map.name %></option>
                            <% END %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="start" class="ctrl-label">Start Station</label>
                        <select id="start" class="form-control form-control-dark"></select>
                    </div>
                    <div class="form-group">
                        <label for="end" class="ctrl-label">End Station</label>
                        <select id="end" class="form-control form-control-dark"></select>
                    </div>
                    <div class="form-group" style="display:flex;gap:12px;align-items:center;">
                        <div style="flex:1;">
                            <label class="ctrl-label">Captcha</label>
                            <input type="text" class="form-control form-control-dark" id="txt_captcha_response" placeholder="Enter answer">
                        </div>
                        <label id="txt_captcha" style="margin-top:22px;font-size:20px;font-family:var(--font-mono);"></label>
                    </div>
                    <button id="map_tube_button" type="button" class="btn-primary-dark">Find Shortest Route</button>
                </div>
                <div id="shortest-route-result" class="response-panel" style="max-width:560px;margin-top:16px;"></div>
            </div>
        </div>
    </div>

